#!/bin/sh
# Keep renders/ in sync with the routed board: when kicad/juku_routed.kicad_pcb is staged,
# regenerate the preview PNGs and stage them too. Install once with:
#   git config core.hooksPath .githooks
if git diff --cached --name-only | grep -q '^kicad/juku_routed\.kicad_pcb$'; then
  echo "pre-commit: routed board changed -> refreshing renders/"
  sh kicad/render_views.sh
  git add renders/*.png
fi
